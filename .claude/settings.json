{
  "permissions": {
    "allow": [
      "Bash(flyctl status *)",
      "Bash(flyctl logs *)",
      "Bash(flyctl secrets list *)",
      "Bash(flyctl apps *)",
      "Bash(flyctl machines *)",
      "Bash(flyctl auth *)",
      "Bash(flyctl version *)",
      "Bash(flyctl help *)",
      "Bash(where *)",
      "Bash(./gradlew *:test *)",
      "Bash(./gradlew *:compileKotlin *)",
      "Bash(./gradlew *:dependencies *)",
      "Bash(./gradlew --version)",
      "Bash(curl -s https://devquest-api.fly.dev/*)",
      "Bash(curl -s https://api.quest.dhbang.co.kr/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/scripts/caveman-activate.sh" }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/scripts/log-event.sh SubagentStart" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/scripts/log-event.sh SubagentStop" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/scripts/assert-not-main.sh" },
          { "type": "command", "command": ".claude/scripts/log-event.sh PreToolUse main" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/scripts/assert-no-main-push.sh" },
          { "type": "command", "command": ".claude/scripts/assert-no-admin.sh" },
          { "type": "command", "command": ".claude/scripts/log-event.sh PreToolUse main" }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": ".claude/scripts/log-event.sh PreToolUse main" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/monitor/generate-report.js" }
        ]
      }
    ]
  }
}
