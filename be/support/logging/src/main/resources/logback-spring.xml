<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProfile name="local">
        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{requestId}] [%X{userId}] [%X{method} %X{uri}] - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="STDOUT"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <springProperty scope="context" name="grafanaLokiUrl"
                        source="GRAFANA_LOKI_URL" defaultValue=""/>
        <springProperty scope="context" name="grafanaLokiInstanceId"
                        source="GRAFANA_LOKI_INSTANCE_ID" defaultValue=""/>
        <springProperty scope="context" name="grafanaApiKey"
                        source="GRAFANA_API_KEY" defaultValue=""/>

        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeContext>false</includeContext>
                <fieldNames>
                    <timestamp>timestamp</timestamp>
                    <message>message</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <level>level</level>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>
            </encoder>
        </appender>

        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>${grafanaLokiUrl}</url>
                <auth>
                    <username>${grafanaLokiInstanceId}</username>
                    <password>${grafanaApiKey}</password>
                </auth>
                <requestTimeoutMs>15000</requestTimeoutMs>
            </http>
            <!-- loki4j 1.x: batchMaxBytes는 <batch> wrapper 없이 appender 최상위에 위치 -->
            <!-- <batch> 섹션은 2.0.0에서 도입됨 — 1.6.0에서는 unknown property 오류 발생 -->
            <batchMaxBytes>65536</batchMaxBytes>
            <format>
                <label>
                    <pattern>app=devquest-api,level=%level</pattern>
                </label>
                <message class="com.github.loki4j.logback.JsonLayout"/>
            </format>
        </appender>

        <root level="INFO">
            <appender-ref ref="STDOUT"/>
            <appender-ref ref="LOKI"/>
        </root>
    </springProfile>

</configuration>
