# 로컬 개발용: .env.local 파일을 만들어서 아래 값을 설정하세요
# .env.local은 git에 커밋되지 않습니다

# API 서버 주소
# 로컬: http://localhost:8080
# 프로덕션: https://api.quest.dhbang.co.kr (Vercel 환경변수에서 설정)
VITE_API_URL=http://localhost:8080

# GitHub OAuth 클라이언트 ID (GitHub OAuth App에서 확인)
VITE_GITHUB_CLIENT_ID=your_github_oauth_client_id
