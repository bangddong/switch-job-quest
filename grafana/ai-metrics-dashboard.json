      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "clamp_min(sum(max_over_time(devquest_ai_call_total[1h]) - min_over_time(devquest_ai_call_total[1h])), 0)",
          "legendFormat": "calls",
          "refId": "A"
